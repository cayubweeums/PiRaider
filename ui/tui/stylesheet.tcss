/* PiRaider TUI: bucket row fills width and scales equally */

CustomHeader {
    width: 100%;
    height: auto;
    min-height: 1;
    padding: 0;
    margin: 0;
    align-horizontal: right;
}

CustomHeader Button {
    background: transparent;
    border: none;
    padding: 0 1;
    margin: 0;
}

BucketsGroup {
    layout: grid;
    grid-size: 3 1;
    grid-columns: 1fr 1fr 1fr;
    grid-gutter: 1;
    width: 100%;
    height: auto;
    padding: 1;
    margin: 0;
}

BucketsGroup Button {
    width: 100%;
    min-width: 0;
}

#wifi_config_actions {
    width: 100%;
    align-horizontal: right;
}

#bluetooth_config_actions {
    width: 100%;
    align-horizontal: right;
}
